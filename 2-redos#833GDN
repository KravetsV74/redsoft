#NFS
dnf install nfs4-acl-tools nfs-utils -y
mkdir /raid/nfs
chmod -R 777 /raid/nfs
nano /etc/exports
#прописать в файл
/raid/nfs       192.168.100.0/27(rw,no_root_squash)
#
systemctl enable --now nfs-server.service
exportfs -arv
#
#На HQ-CLI
